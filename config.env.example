# انسخ هذا الملف باسم:  config.env   ثم املأ القيم.
# (ملف config.env لا يُرفع على GitHub — يبقى خاصاً على استضافتك)

# مفتاح Groq المجاني (مطلوب للحُكم والشرح) — من https://console.groq.com
GROQ_API_KEY=ضع_مفتاح_groq_هنا

# رابط موقعك النهائي على السب دومين (مع / في النهاية)
SITE_URL=https://radar.example.com/

# مجلد نشر الموقع = مجلد public_html الخاص بالسب دومين (المسار الكامل من hPanel)
SITE_DIR=/home/uXXXXXXXX/domains/example.com/public_html/radar

# فترة التحديث بالدقائق (يجب أن تقسم 60: 15 أو 30). لازم تطابق جدولة الـ cron.
SCAN_INTERVAL_MIN=30

# اختياري: رمز GitHub لرفع حد الطلبات (يعمل بدونه). أنشئه من:
# github.com/settings/tokens (Fine-grained, صلاحية Public read فقط)
# GITHUB_TOKEN=
